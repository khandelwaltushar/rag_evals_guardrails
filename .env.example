# Copy to `.env` and fill in:  cp .env.example .env
# Never commit `.env` (gitignored).

# Embeddings + (if LLM_PROVIDER=openai) chat/judge — required for OpenAI paths
OPENAI_API_KEY=

# Required when LLM_PROVIDER=anthropic — chat, judge, rerank, self-check
ANTHROPIC_API_KEY=

# openai | anthropic | ollama (ollama = local, no keys required)
LLM_PROVIDER=openai

# openai | local (local = sentence-transformers, no keys required)
EMBEDDER_PROVIDER=openai

# Chat model:
#   openai    -> gpt-* (e.g. gpt-4o-mini)
#   anthropic -> claude-* (e.g. claude-3-5-haiku-20241022)
#   ollama    -> local tag (e.g. llama3.2:3b, qwen2.5:7b)
CHAT_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini

# Embedding model:
#   openai -> text-embedding-3-small
#   local  -> sentence-transformers model id (e.g. BAAI/bge-small-en-v1.5)
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI-compatible base URL for Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1

RAG_DEBUG=false

# Optional — leave empty to skip Redis
REDIS_URL=

FAISS_INDEX_PATH=./data/faiss_index
BM25_CORPUS_PATH=./data/bm25_corpus.json
